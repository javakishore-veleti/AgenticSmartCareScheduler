{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CFN",
      "Effect": "Allow",
      "Action": [
        "cloudformation:Create*",
        "cloudformation:Update*",
        "cloudformation:Delete*",
        "cloudformation:Describe*",
        "cloudformation:Execute*",
        "cloudformation:GetTemplate",
        "cloudformation:List*"
      ],
      "Resource": "arn:aws:cloudformation:*:*:stack/smartcare-*/*"
    },
    {
      "Sid": "IAM",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PassRole",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:List*Policies"
      ],
      "Resource": "arn:aws:iam::*:role/smartcare-*"
    },
    {
      "Sid": "S3",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": ["arn:aws:s3:::smartcare-*", "arn:aws:s3:::smartcare-*/*"]
    },
    {
      "Sid": "SSM",
      "Effect": "Allow",
      "Action": ["ssm:PutParameter", "ssm:GetParameter", "ssm:DeleteParameter"],
      "Resource": "arn:aws:ssm:*:*:parameter/smartcare/*"
    }
  ]
}
